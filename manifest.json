{
  "manifest_version": 3,
  "name": "URL Scanner",
  "version": "1.0.0",
  "description": "Scan thousands of URLs and report their status",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open URL Scanner"
  },
  "options_page": "src/pages/dashboard/index.html"
}
